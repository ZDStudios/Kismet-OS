[Desktop Entry]
Type=Application
Version=1.0
Name=Run Windows App
Comment=Launch a .exe or .msi with the Kismet compatibility layer
Exec=/usr/local/bin/kismet-run-exe %f
Icon=kismet-run-exe
Terminal=false
Categories=System;Utility;
StartupNotify=true
MimeType=application/x-ms-dos-executable;application/x-msi;application/x-ms-shortcut;
