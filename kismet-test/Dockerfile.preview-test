FROM dorowu/ubuntu-desktop-lxde-vnc:focal

ENV DEBIAN_FRONTEND=noninteractive \
    VNC_PW=kismet

RUN rm -f /etc/apt/sources.list.d/google-chrome.list /etc/apt/sources.list.d/google.list || true \
    && apt-get update && apt-get install -y \
    curl wget git vim neovim jq zsh tmux ca-certificates \
    python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY preview-entrypoint.sh /usr/local/bin/preview-entrypoint.sh
RUN chmod +x /usr/local/bin/preview-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/preview-entrypoint.sh"]
