#!/usr/bin/env bash
set -euo pipefail

provider="${1:-}"
if [ -z "$provider" ]; then
  echo "Usage: kismet-ai-bootstrap <hermes|opencode|openclaw|ollama>" >&2
  exit 1
fi

show_message() {
  local level="$1"
  local text="$2"
  if command -v zenity >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    case "$level" in
      info) zenity --info --title="Kismet AI Suite" --text="$text" >/dev/null 2>&1 || true ;;
      error) zenity --error --title="Kismet AI Suite" --text="$text" >/dev/null 2>&1 || true ;;
      *) zenity --warning --title="Kismet AI Suite" --text="$text" >/dev/null 2>&1 || true ;;
    esac
  elif command -v kdialog >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    case "$level" in
      info) kdialog --title "Kismet AI Suite" --msgbox "$text" ;;
      error) kdialog --title "Kismet AI Suite" --error "$text" ;;
      *) kdialog --title "Kismet AI Suite" --sorry "$text" ;;
    esac
  else
    printf '%s\n' "$text"
  fi
}

case "$provider" in
  hermes)
    if command -v kismet-hermes >/dev/null 2>&1 || command -v hermes >/dev/null 2>&1 || command -v openclaw >/dev/null 2>&1; then
      show_message info "Hermes is already available in this Kismet image."
      exit 0
    fi
    show_message error "Hermes is missing from this image. Rebuild the preview with the bundled Hermes runtime."
    exit 1
    ;;
  opencode)
    if command -v opencode >/dev/null 2>&1 || command -v claude >/dev/null 2>&1 || command -v openclaw >/dev/null 2>&1; then
      show_message info "OpenCode is already available in this Kismet image."
      exit 0
    fi
    show_message error "OpenCode is missing from this image. Rebuild the preview with Node.js and the bundled coding CLI."
    exit 1
    ;;
  openclaw)
    if command -v openclaw >/dev/null 2>&1; then
      show_message info "OpenClaw is already installed."
      exit 0
    fi
    show_message error "OpenClaw is missing from this image. Rebuild the preview with the bundled OpenClaw runtime."
    exit 1
    ;;
  ollama)
    if command -v ollama >/dev/null 2>&1; then
      show_message info "Ollama is already installed."
      exit 0
    fi
    show_message error "Ollama is missing from this image. Rebuild the preview with the bundled Ollama runtime."
    exit 1
    ;;
  *)
    show_message error "Unknown provider: $provider"
    exit 1
    ;;
esac
