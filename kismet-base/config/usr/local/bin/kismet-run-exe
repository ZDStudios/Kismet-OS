#!/usr/bin/env bash
set -euo pipefail

show_message() {
  local level="$1"
  local text="$2"
  if command -v kdialog >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    case "$level" in
      error) kdialog --title "Kismet OS" --error "$text" ;;
      info) kdialog --title "Kismet OS" --msgbox "$text" ;;
      *) kdialog --title "Kismet OS" --sorry "$text" ;;
    esac
  else
    printf '%s\n' "$text" >&2
  fi
}

pick_target() {
  if command -v kdialog >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    kdialog --title "Kismet OS" --getopenfilename "$HOME" '*.exe *.msi *.bat *.cmd|Windows apps'
  fi
}

ensure_prefix() {
  export WINEPREFIX="${WINEPREFIX:-$HOME/.local/share/kismet/wineprefix}"
  export WINEDEBUG="${WINEDEBUG:--all}"
  export WINEDLLOVERRIDES="mscoree,mshtml="
  mkdir -p "$WINEPREFIX" "$HOME/.cache/kismet" "$HOME/.local/state/kismet"

  local stamp="$WINEPREFIX/.kismet-prefix-ready"
  if command -v wineboot >/dev/null 2>&1 && [ ! -f "$stamp" ]; then
    if wineboot -u >/dev/null 2>&1; then
      touch "$stamp"
    fi
  fi

  if command -v winetricks >/dev/null 2>&1; then
    local corefonts_stamp="$HOME/.cache/kismet/winetricks-corefonts.done"
    if [ ! -f "$corefonts_stamp" ]; then
      winetricks -q corefonts >/dev/null 2>&1 || true
      touch "$corefonts_stamp"
    fi
  fi
}

run_runtime() {
  local runtime="$1"
  local target="$2"
  shift 2
  local log_file="$HOME/.local/state/kismet/windows-launch.log"
  printf '\n[%s] launching %s with %s\n' "$(date -Is)" "$target" "$runtime" >>"$log_file"
  
  # Use a persistent terminal so the app doesn't close immediately
  local term_cmd=""
  if command -v konsole >/dev/null 2>&1; then
    term_cmd="konsole -e"
  elif command -v gnome-terminal >/dev/null 2>&1; then
    term_cmd="gnome-terminal --"
  elif command -v xterm >/dev/null 2>&1; then
    term_cmd="xterm -e"
  fi
  
  if [ -n "$term_cmd" ]; then
    case "$EXT" in
      msi)
        $term_cmd env WINEPREFIX="$WINEPREFIX" WINEDEBUG="$WINEDEBUG" wine64 msiexec /i "$target" "$@" >>"$log_file" 2>&1 &
        ;;
      bat|cmd)
        $term_cmd env WINEPREFIX="$WINEPREFIX" WINEDEBUG="$WINEDEBUG" wine64 cmd /c "$target" "$@" >>"$log_file" 2>&1 &
        ;;
      *)
        $term_cmd env WINEPREFIX="$WINEPREFIX" WINEDEBUG="$WINEDEBUG" wine64 "$target" "$@" >>"$log_file" 2>&1 &
        ;;
    esac
    # Give it a moment to start
    sleep 1
    return 0
  fi
  
  # Fallback: direct launch (will likely close immediately)
  case "$EXT" in
    msi)
      "$runtime" msiexec /i "$target" "$@" >>"$log_file" 2>&1
      ;;
    bat|cmd)
      "$runtime" cmd /c "$target" "$@" >>"$log_file" 2>&1
      ;;
    *)
      "$runtime" "$target" "$@" >>"$log_file" 2>&1
      ;;
  esac
}

TARGET="${1:-}"
if [ -z "$TARGET" ]; then
  TARGET="$(pick_target || true)"
fi

if [ -z "$TARGET" ]; then
  show_message info "Choose a Windows installer or application to launch."
  exit 1
fi

if [ ! -f "$TARGET" ]; then
  show_message error "Windows app not found:\n$TARGET"
  exit 1
fi

EXT="${TARGET##*.}"
EXT="$(printf '%s' "$EXT" | tr '[:upper:]' '[:lower:]')"
case "$EXT" in
  exe|msi|bat|cmd) ;;
  *)
    show_message error "Unsupported Windows file type: .$EXT"
    exit 1
    ;;
esac

shift $(( $# > 0 ? 1 : 0 )) || true
ensure_prefix

if command -v wine64 >/dev/null 2>&1; then
  if run_runtime wine64 "$TARGET" "$@"; then
    exit 0
  fi
  status=$?
  show_message error "The Windows app closed unexpectedly.\n\nCheck ~/.local/state/kismet/windows-launch.log for details.\nExit code: $status"
  exit "$status"
fi

if command -v wine >/dev/null 2>&1; then
  if run_runtime wine "$TARGET" "$@"; then
    exit 0
  fi
  status=$?
  show_message error "The Windows app closed unexpectedly.\n\nCheck ~/.local/state/kismet/windows-launch.log for details.\nExit code: $status"
  exit "$status"
fi

show_message error "No Windows compatibility runtime found. Install Wine first."
exit 1
