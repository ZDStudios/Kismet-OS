#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: kismet-run-exe /path/to/app.exe [args...]" >&2
  exit 1
fi

if command -v lutris >/dev/null 2>&1; then
  exec lutris "$@"
fi

if command -v wine >/dev/null 2>&1; then
  exec wine "$@"
fi

echo "No Windows compatibility runtime found. Install Wine or Lutris first." >&2
exit 1
