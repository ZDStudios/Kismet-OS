#!/usr/bin/env bash
# Kismet GNOME Polish - Apply Zorin-style GNOME theming on first login

set -euo pipefail

# Apply Yaru theme (Zorin uses a Ubuntu-based theme)
if command -v gsettings >/dev/null 2>&1; then
  # GTK theme
  gsettings set org.gnome.desktop.interface gtk-theme 'Yaru'
  gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark'
  gsettings set org.gnome.desktop.interface cursor-theme 'Yaru'
  gsettings set org.gnome.desktop.interface cursor-size 24
  
  # Desktop background
  gsettings set org.gnome.desktop.background picture-uri 'file:///usr/share/backgrounds/kismet/kismet-wallpaper.svg'
  gsettings set org.gnome.desktop.background picture-uri-dark 'file:///usr/share/backgrounds/kismet/kismet-wallpaper.svg'
  gsettings set org.gnome.desktop.background primary-color '#101828'
  gsettings set org.gnome.desktop.background secondary-color '#1cb4ff'
  
  # Shell theme
  gsettings set org.gnome.shell.extensions.user-theme name 'Yaru-dark'
  
  # Font settings
  gsettings set org.gnome.desktop.interface font-name 'Ubuntu 11'
  gsettings set org.gnome.desktop.interface document-font-name 'Ubuntu 11'
  gsettings set org.gnome.desktop.interface monospace-font-name 'Ubuntu Mono 11'
  
  # Interface tweaks
  gsettings set org.gnome.desktop.interface show-icons-sysmenus true
  gsettings set org.gnome.desktop.interface labels-first true
  gsettings set org.gnome.desktop.interface button-layout ':minimize,maximize,close'
  gsettings set org.gnome.desktop.interface titlebar-layout 'minimize,maximize,close'
  
  # Dock/Desktop
  gsettings set org.gnome.shell.extensions.dash-to-dock dock-position 'BOTTOM'
  gsettings set org.gnome.shell.extensions.dash-to-dock dock-alignment 0.5
  gsettings set org.gnome.shell.extensions.dash-to-dock show-mounts false
  gsettings set org.gnome.shell.extensions.dash-to-dock show-icons-only-on-primary true
  
  # Privacy
  gsettings set org.gnome.desktop.privacy remove-old-temp-files true
  gsettings set org.gnome.desktop.privacy old-files-age 7
  
  # Power settings
  gsettings set org.gnome.settings-daemon.plugins.power power-button-action 'suspend'
  gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type 'suspend'
  gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-battery-type 'suspend'
  
  # Sound
  gsettings set org.gnome.desktop.sound event-sounds true
  gsettings set org.gnome.desktop.sound input-feedback-sounds false
fi

# Enable GNOME extensions that make it look like Zorin
if command -v gnome-extensions >/dev/null 2>&1; then
  # Enable dash-to-dock if available
  gnome-extensions enable dash-to-dock@micahg.github.com 2>/dev/null || true
  # Enable desktop-icons if available
  gnome-extensions enable desktop-icons@csoriano 2>/dev/null || true
fi

# Set up GNOME favorites (Zorin-style)
if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.shell favorite-apps "[
    'org.gnome.Nautilus.desktop',
    'org.gnome.Terminal.desktop',
    'org.gnome.TextEditor.desktop',
    'org.gnome.Calculator.desktop',
    'org.gnome.Settings.desktop',
    'firefox.desktop',
    'kismet.desktop'
  ]"
fi

echo "==> Kismet GNOME polish applied (Zorin OS style)"