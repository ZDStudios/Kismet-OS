#!/usr/bin/env bash
set -euo pipefail

provider="${1:-}"
shift || true

show_message() {
  local text="$1"
  if command -v zenity >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    zenity --error --title="Kismet AI Suite" --text="$text" >/dev/null 2>&1 || true
  elif command -v kdialog >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    kdialog --title "Kismet AI Suite" --error "$text" >/dev/null 2>&1 || true
  else
    printf '%s\n' "$text" >&2
  fi
}

find_command() {
  local name
  for name in "$@"; do
    if command -v "$name" >/dev/null 2>&1; then
      command -v "$name"
      return 0
    fi
  done
  return 1
}

launch_in_terminal() {
  if command -v gnome-terminal >/dev/null 2>&1; then
    exec gnome-terminal -- "$@"
  elif command -v ptyxis >/dev/null 2>&1; then
    exec ptyxis -- "$@"
  elif command -v kgx >/dev/null 2>&1; then
    exec kgx "$@"
  elif command -v xterm >/dev/null 2>&1; then
    exec xterm -e "$@"
  fi
  exec "$@"
}

case "$provider" in
  hermes)
    cmd="$(find_command kismet-hermes hermes || true)"
    ;;
  opencode)
    cmd="$(find_command opencode || true)"
    ;;
  openclaw)
    cmd="$(find_command openclaw || true)"
    ;;
  ollama)
    cmd="$(find_command ollama || true)"
    ;;
  *)
    show_message "Unknown Kismet AI provider: $provider"
    exit 1
    ;;
esac

if [ -z "$cmd" ]; then
  case "$provider" in
    hermes)
      show_message "Hermes AI Agent is not available in this preview image yet."
      ;;
    opencode)
      show_message "OpenCode is not available in this preview image yet."
      ;;
    *)
      show_message "$provider is not installed in this preview image yet."
      ;;
  esac
  exit 1
fi

case "$provider" in
  ollama)
    launch_in_terminal "$cmd" "$@"
    ;;
  *)
    launch_in_terminal "$cmd" "$@"
    ;;
esac
