#!/usr/bin/env python3
"""CLI for the Kismet preview agent."""

from __future__ import annotations

import argparse
import json
import sys
from datetime import timedelta
from urllib import error, request

BASE_URL = "http://127.0.0.1:7731"


def api_call(path: str, method: str = "GET", payload: dict | None = None):
    data = None
    headers = {"Accept": "application/json"}
    if payload is not None:
        data = json.dumps(payload).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = request.Request(f"{BASE_URL}{path}", data=data, headers=headers, method=method)
    with request.urlopen(req, timeout=10) as response:
        return json.loads(response.read().decode("utf-8"))


def cmd_status(_args):
    status = api_call("/status")
    hardware = api_call("/hardware")
    uptime = timedelta(seconds=status.get("uptime_seconds", 0))
    print(f"Kismet Agent {status.get('version', '?')} [{status.get('status', '?')}]")
    print(f"Uptime: {uptime}")
    print(f"Habits learned: {status.get('habits_learned', 0)}")
    print(f"Tasks automated: {status.get('tasks_automated', 0)}")
    cpu = hardware.get("cpu", {})
    mem = hardware.get("memory", {})
    print(f"CPU: {cpu.get('percent', 0)}% {cpu.get('model', '')}")
    print(f"Memory: {mem.get('used_gb', 0)} / {mem.get('total_gb', 0)} GB")


def cmd_hardware(_args):
    print(json.dumps(api_call("/hardware"), indent=2))


def cmd_habits(args):
    path = f"/habits?limit={args.limit}" if args.verbose else "/habits/stats"
    print(json.dumps(api_call(path), indent=2))


def cmd_ollama(args):
    if args.ollama_cmd == "list":
        print(json.dumps(api_call("/ollama/models"), indent=2))
    elif args.ollama_cmd == "pull":
        print(json.dumps(api_call("/ollama/pull", method="POST", payload={"model": args.model}), indent=2))


def cmd_scheduler(args):
    if args.scheduler_cmd == "list":
        print(json.dumps(api_call("/scheduler/tasks"), indent=2))
    else:
        print(json.dumps(api_call("/scheduler/run", method="POST", payload={"task": args.task}), indent=2))


def main() -> int:
    parser = argparse.ArgumentParser(description="Kismet preview CLI")
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("status").set_defaults(func=cmd_status)
    sub.add_parser("hardware").set_defaults(func=cmd_hardware)
    habits = sub.add_parser("habits")
    habits.add_argument("-v", "--verbose", action="store_true")
    habits.add_argument("-n", "--limit", type=int, default=20)
    habits.set_defaults(func=cmd_habits)
    ollama = sub.add_parser("ollama")
    ollama.add_argument("ollama_cmd", choices=["list", "pull"])
    ollama.add_argument("model", nargs="?")
    ollama.set_defaults(func=cmd_ollama)
    scheduler = sub.add_parser("scheduler")
    scheduler.add_argument("scheduler_cmd", choices=["list", "run"])
    scheduler.add_argument("task", nargs="?")
    scheduler.set_defaults(func=cmd_scheduler)
    args = parser.parse_args()
    try:
        args.func(args)
        return 0
    except error.URLError as exc:
        print(f"kismet-ctl: could not reach agent at {BASE_URL}: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
