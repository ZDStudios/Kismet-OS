#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import shutil
import subprocess
from pathlib import Path

AGENT_URL = "http://127.0.0.1:7731/recommendations/models"
CONFIG_DIR = Path.home() / ".kismet"
CONFIG_DIR.mkdir(parents=True, exist_ok=True)
USER_CONFIG = CONFIG_DIR / "firstboot.json"
USER_AI_STATE = CONFIG_DIR / "ai-stack-state.json"
SYSTEM_MODEL_ENV = Path("/etc/kismet/models.env")
SYSTEM_AI_STACK = Path("/etc/kismet/ai-stack.json")
OPENCLAW_OLLAMA_CONFIG = Path("/etc/openclaw/ollama.env")
INSTALL_LOG = CONFIG_DIR / "firstboot-install.log"
OPENCLAW_TEMPLATE = Path("/etc/openclaw/config.d/20-kismet-local-ollama.json")


def fetch_recommendations() -> dict:
    import urllib.request
    with urllib.request.urlopen(AGENT_URL, timeout=10) as resp:
        return json.loads(resp.read().decode("utf-8"))


def ask_bool_cli(prompt: str, default: bool = True) -> bool:
    suffix = "[Y/n]" if default else "[y/N]"
    raw = input(f"{prompt} {suffix} ").strip().lower()
    if not raw:
        return default
    return raw in {"y", "yes"}


def detect_claude_code_pkg() -> str:
    return os.environ.get("KISMET_CLAUDE_CODE_PACKAGE", "@anthropic-ai/claude-code")


def write_file(path: Path, content: str, sudo: bool = False) -> None:
    if sudo:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp = CONFIG_DIR / f".{path.name}.tmp"
        tmp.write_text(content, encoding="utf-8")
        subprocess.run(["sudo", "install", "-Dm644", str(tmp), str(path)], check=False)
        tmp.unlink(missing_ok=True)
    else:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")


def run_logged(label: str, command: list[str] | str, shell: bool = False) -> dict:
    proc = subprocess.run(command, shell=shell, capture_output=True, text=True)
    with INSTALL_LOG.open("a", encoding="utf-8") as handle:
        handle.write(f"\n## {label}\n")
        handle.write(f"command: {command}\n")
        handle.write(f"exit: {proc.returncode}\n")
        if proc.stdout:
            handle.write("stdout:\n" + proc.stdout + "\n")
        if proc.stderr:
            handle.write("stderr:\n" + proc.stderr + "\n")
    return {"ok": proc.returncode == 0, "code": proc.returncode, "stdout": proc.stdout, "stderr": proc.stderr}


def gui_available() -> bool:
    return bool(os.environ.get("DISPLAY")) and shutil.which("kdialog") is not None


def gui_menu(_title: str, text: str, options: list[tuple[str, str]], default_tag: str) -> str:
    cmd = ["kdialog", "--title", "Kismet OS", "--menu", text]
    for tag, label in options:
        cmd.extend([tag, label])
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if proc.returncode == 0 and proc.stdout.strip():
        return proc.stdout.strip()
    return default_tag


def gui_checklist(title: str, text: str, options: list[tuple[str, str, bool]]) -> list[str]:
    cmd = ["kdialog", "--title", title, "--separate-output", "--checklist", text]
    for tag, label, enabled in options:
        cmd.extend([tag, label, "on" if enabled else "off"])
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if proc.returncode == 0:
        return [line.strip() for line in proc.stdout.splitlines() if line.strip()]
    return [tag for tag, _, enabled in options if enabled]


def collect_answers(profile: dict, recommended: list[dict]) -> dict:
    suggested_models = [item["name"] for item in recommended]
    if gui_available():
        subprocess.run([
            "kdialog", "--title", "Kismet OS", "--msgbox",
            "\n".join([
                "Welcome to Kismet OS",
                "",
                "This wizard configures the Zorin-inspired desktop, the local AI stack, and Windows app compatibility.",
                f"Detected profile: {profile.get('tier', 'unknown')}",
                f"CPU: {profile.get('cpu', 'unknown')}",
                f"RAM: {profile.get('memory_gib', '?')} GiB",
            ])
        ], check=False)

        profile_choice = gui_menu(
            "Kismet OS",
            "Choose your preferred AI profile",
            [
                ("minimal", "Minimal, lowest resource usage"),
                ("balanced", "Balanced, sensible defaults"),
                ("builder", "Builder, stronger coding and assistant models"),
                ("max", "Maximum local AI footprint"),
            ],
            "balanced",
        )

        desktop_mode = gui_menu(
            "Kismet OS",
            "Choose your desktop layout",
            [
                ("zorin-inspired-plasma", "Zorin-inspired Plasma, recommended"),
                ("classic-plasma", "Classic Plasma"),
            ],
            "zorin-inspired-plasma",
        )

        defaults_by_profile = {
            "minimal": ["llama3.2:1b", "qwen2.5-coder:1.5b"],
            "balanced": suggested_models or ["llama3.2:3b", "qwen2.5-coder:3b", "nomic-embed-text"],
            "builder": ["qwen2.5-coder:7b", "llama3.1:8b", "nomic-embed-text"],
            "max": ["qwen2.5-coder:14b", "llama3.1:8b", "deepseek-r1:14b", "nomic-embed-text"],
        }
        model_defaults = defaults_by_profile.get(profile_choice, suggested_models)
        choices = gui_checklist(
            "Kismet OS",
            "Select Ollama models to preload",
            [(name, name, name in model_defaults) for name in [
                "llama3.2:1b", "llama3.2:3b", "llama3.1:8b", "qwen2.5-coder:1.5b", "qwen2.5-coder:3b", "qwen2.5-coder:7b", "qwen2.5-coder:14b", "phi4-mini", "deepseek-r1:14b", "nomic-embed-text"
            ]],
        ) or model_defaults

        providers = set(gui_checklist(
            "Kismet OS",
            "Enable AI providers",
            [
                ("hermes", "Hermes AI Agent, primary agent layer", True),
                ("opencode", "OpenCode, coding-oriented agent layer", True),
                ("openclaw", "OpenClaw local assistant integration", True),
                ("ollama", "Ollama local model runtime", True),
            ],
        ))
        tasks = set(gui_checklist(
            "Kismet OS",
            "Select setup actions",
            [
                ("ollama", "Install and enable Ollama", True),
                ("openclaw", "Install OpenClaw", True),
                ("claude", "Install Claude Code", True),
                ("windows", "Enable Windows app compatibility helpers", True),
            ],
        ))
        preferred_provider = gui_menu(
            "Kismet OS",
            "Choose the preferred AI provider",
            [(name, name.title()) for name in ["hermes", "opencode", "openclaw", "ollama"] if name in providers] or [("hermes", "Hermes")],
            "hermes",
        )
        return {
            "profile_mode": profile_choice,
            "desktop_mode": desktop_mode,
            "models": choices,
            "providers": sorted(providers),
            "preferred_provider": preferred_provider,
            "install_ollama": "ollama" in tasks,
            "install_openclaw": "openclaw" in tasks,
            "install_claude_code": "claude" in tasks,
            "enable_windows_compat": "windows" in tasks,
            "connect_openclaw_ollama": True,
        }

    print("==> Welcome to Kismet OS")
    print(f"Detected profile: {profile.get('tier', 'unknown')} | CPU: {profile.get('cpu', 'unknown')} | RAM: {profile.get('memory_gib', '?')} GiB")
    print("Suggested Ollama models:")
    for item in recommended:
        print(f"  - {item['name']}: {item['reason']}")
    raw_models = input("Models to preload (space-separated, blank for suggested): ").strip()
    providers_raw = input("Providers to enable [hermes opencode openclaw ollama]: ").strip()
    providers = providers_raw.split() if providers_raw else ["hermes", "opencode", "openclaw", "ollama"]
    preferred_provider = input("Preferred provider [hermes]: ").strip() or "hermes"
    return {
        "profile_mode": "balanced",
        "desktop_mode": "zorin-inspired-plasma",
        "models": raw_models.split() if raw_models else suggested_models,
        "providers": providers,
        "preferred_provider": preferred_provider,
        "install_ollama": ask_bool_cli("Install and enable Ollama?", True),
        "install_openclaw": ask_bool_cli("Install OpenClaw?", True),
        "install_claude_code": ask_bool_cli("Install Claude Code?", True),
        "enable_windows_compat": ask_bool_cli("Enable Windows app compatibility helpers?", True),
        "connect_openclaw_ollama": True,
    }


def render_openclaw_template(models: list[str]) -> str:
    preferred = models[0] if models else "llama3.2:3b"
    return json.dumps(
        {
            "kismet": {
                "generated": True,
                "ollama": {
                    "baseUrl": "http://127.0.0.1:11434",
                    "preferredModel": preferred,
                    "embeddingModel": "nomic-embed-text" if "nomic-embed-text" in models else None,
                    "fallbackModels": models[1:4],
                },
                "notes": [
                    "Template generated by Kismet first boot wizard.",
                    "Merge this with the host OpenClaw config according to the local deployment layout.",
                ],
            }
        },
        indent=2,
    ) + "\n"


def render_ai_stack(answers: dict) -> str:
    providers = {
        name: {
            "enabled": name in answers["providers"],
            "command": name,
            "label": {
                "hermes": "Hermes AI Agent",
                "opencode": "OpenCode",
                "openclaw": "OpenClaw",
                "ollama": "Ollama",
            }.get(name, name.title()),
        }
        for name in ["hermes", "opencode", "openclaw", "ollama"]
    }
    payload = {
        "kernelAware": True,
        "desktopMode": answers.get("desktop_mode", "zorin-inspired-plasma"),
        "modelStrategy": "auto-recommend",
        "preferredProvider": answers.get("preferred_provider", "hermes"),
        "providerPriority": ["hermes", "opencode", "openclaw", "ollama"],
        "providers": providers,
        "windowsCompatibility": {
            "enabled": answers.get("enable_windows_compat", True),
            "preferredRuntimes": ["lutris", "wine", "winetricks"],
        },
    }
    return json.dumps(payload, indent=2) + "\n"


def main() -> int:
    INSTALL_LOG.parent.mkdir(parents=True, exist_ok=True)
    INSTALL_LOG.write_text("# Kismet first boot install log\n", encoding="utf-8")
    try:
        rec = fetch_recommendations()
    except Exception as exc:
        rec = {"profile": {"tier": "balanced"}, "recommended": []}
        with INSTALL_LOG.open("a", encoding="utf-8") as handle:
            handle.write(f"recommendation fetch failed: {exc}\n")

    profile = rec.get("profile", {})
    recommended = rec.get("recommended", [])
    answers = collect_answers(profile, recommended)
    models = answers["models"]

    state = {
        "profile": profile,
        **answers,
    }
    write_file(USER_CONFIG, json.dumps(state, indent=2))
    write_file(USER_AI_STATE, render_ai_stack(answers))

    results: dict[str, dict] = {}

    if answers["install_ollama"]:
        results["ollama_enable"] = run_logged("enable ollama", ["sudo", "systemctl", "enable", "--now", "ollama.service"])
        write_file(SYSTEM_MODEL_ENV, f"KISMET_OLLAMA_MODELS='{' '.join(models)}'\nKISMET_OLLAMA_KEEP_ALIVE='30m'\n", sudo=True)
        results["ollama_loader_enable"] = run_logged("enable ollama loader", ["sudo", "systemctl", "enable", "kismet-ollama-loader.service"])
        results["ollama_loader_start"] = run_logged("start ollama loader", ["sudo", "systemctl", "start", "kismet-ollama-loader.service"])

    write_file(SYSTEM_AI_STACK, render_ai_stack(answers), sudo=True)

    if answers["install_openclaw"]:
        installer = shutil.which("openclaw")
        if installer:
            results["openclaw_present"] = {"ok": True, "code": 0, "stdout": "openclaw already present", "stderr": ""}
        else:
            results["openclaw_install"] = run_logged("install openclaw", ["bash", "-lc", "curl -fsSL https://openclaw.ai/install.sh | sh"])

    if answers["install_claude_code"]:
        pkg = detect_claude_code_pkg()
        if shutil.which("claude"):
            results["claude_code_present"] = {"ok": True, "code": 0, "stdout": "claude already present", "stderr": ""}
        else:
            results["claude_code_install"] = run_logged("install claude code", ["sudo", "npm", "install", "-g", pkg])

    if answers["enable_windows_compat"]:
        if shutil.which("wine"):
            results["wine_present"] = {"ok": True, "code": 0, "stdout": "wine already present", "stderr": ""}
        else:
            results["wine_hint"] = {"ok": False, "code": 1, "stdout": "", "stderr": "wine not installed in current environment"}

    write_file(OPENCLAW_OLLAMA_CONFIG, "OLLAMA_HOST=http://127.0.0.1:11434\nOPENCLAW_OLLAMA_ENABLED=true\n", sudo=True)
    write_file(OPENCLAW_TEMPLATE, render_openclaw_template(models), sudo=True)

    failed = [name for name, result in results.items() if not result.get("ok", False)]
    message = "Kismet first boot setup complete." if not failed else f"Kismet first boot completed with some failed steps: {', '.join(failed)}"

    if gui_available():
        subprocess.run(["kdialog", "--title", "Kismet OS", "--msgbox", message + f"\n\nSelections saved to {USER_CONFIG}\nLog: {INSTALL_LOG}"], check=False)
    else:
        print(message)
        print("Selections saved to", USER_CONFIG)
        print("Log:", INSTALL_LOG)

    return 0 if not failed else 1


if __name__ == "__main__":
    raise SystemExit(main())
