{
  "identity": "Kismet AI Suite",
  "kernelAware": true,
  "desktopMode": "zorin-inspired-plasma",
  "modelStrategy": "auto-recommend",
  "preferredProvider": "hermes",
  "providerPriority": ["hermes", "opencode", "openclaw", "ollama"],
  "providers": {
    "hermes": {
      "enabled": true,
      "command": "kismet-ai-launch",
      "commandArgs": ["hermes"],
      "binaryCandidates": ["hermes", "openclaw", "claude"],
      "label": "Hermes AI Agent",
      "role": "primary-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap hermes",
      "installHint": "Use Kismet AI Center to bootstrap Hermes or wire a vendor package into the release image."
    },
    "opencode": {
      "enabled": true,
      "command": "kismet-ai-launch",
      "commandArgs": ["opencode"],
      "binaryCandidates": ["opencode", "claude", "openclaw"],
      "label": "OpenCode",
      "role": "coding-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap opencode",
      "installHint": "Use Kismet AI Center to bootstrap OpenCode or wire a vendor package into the release image."
    },
    "openclaw": {
      "enabled": true,
      "command": "openclaw",
      "binaryCandidates": ["openclaw"],
      "label": "OpenClaw",
      "role": "system-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap openclaw",
      "installHint": "Install OpenClaw through the Kismet first boot wizard or AI Center."
    },
    "ollama": {
      "enabled": true,
      "command": "ollama",
      "binaryCandidates": ["ollama"],
      "label": "Ollama",
      "role": "local-model-runtime",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap ollama",
      "installHint": "Install Ollama through the Kismet first boot wizard."
    }
  },
  "windowsCompatibility": {
    "enabled": true,
    "preferredRuntimes": ["lutris", "wine64", "wine", "winetricks"],
    "notes": [
      "Kismet OS uses user-space compatibility layers for .exe files.",
      "This is practical Windows app support, not magical native execution."
    ]
  }
}
