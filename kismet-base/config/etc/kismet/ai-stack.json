{
  "identity": "Kismet AI Suite",
  "kernelAware": true,
  "desktopMode": "zorin-inspired-gnome",
  "modelStrategy": "auto-recommend",
  "preferredProvider": "hermes",
  "providerPriority": ["hermes", "opencode", "openclaw", "ollama"],
  "providers": {
    "hermes": {
      "enabled": true,
      "command": "kismet-ai-launch",
      "commandArgs": ["hermes"],
      "binaryCandidates": ["kismet-hermes", "openclaw", "claude"],
      "label": "Hermes AI Agent",
      "role": "primary-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap hermes",
      "installHint": "Hermes is expected to be preinstalled in the preview image. If it is missing, repair the local runtime bundle."
    },
    "opencode": {
      "enabled": true,
      "command": "kismet-ai-launch",
      "commandArgs": ["opencode"],
      "binaryCandidates": ["opencode", "claude", "openclaw"],
      "label": "OpenCode",
      "role": "coding-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap opencode",
      "installHint": "OpenCode requires the bundled Node.js runtime and CLI package in the preview image."
    },
    "openclaw": {
      "enabled": true,
      "command": "openclaw",
      "binaryCandidates": ["openclaw"],
      "label": "OpenClaw",
      "role": "system-agent",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap openclaw",
      "installHint": "OpenClaw should be bundled in the preview image."
    },
    "ollama": {
      "enabled": true,
      "command": "ollama",
      "binaryCandidates": ["ollama"],
      "label": "Ollama",
      "role": "local-model-runtime",
      "launchMode": "terminal",
      "bootstrapCommand": "kismet-ai-bootstrap ollama",
      "installHint": "Ollama should be bundled in the preview image."
    }
  },
  "windowsCompatibility": {
    "enabled": true,
    "preferredRuntimes": ["lutris", "wine64", "wine", "winetricks"],
    "notes": [
      "Kismet OS uses user-space compatibility layers for .exe files.",
      "This is practical Windows app support, not magical native execution."
    ]
  }
}
