[Unit]
Description=Kismet Ollama Bridge
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/lib/kismet/ollama_bridge.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/usr/local/lib/kismet

[Install]
WantedBy=multi-user.target
